# ──────────────────────────────────────────────────────────────────────────────
# Database — SQLite (file-based, no separate server needed)
# ──────────────────────────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ──────────────────────────────────────────────────────────────────────────────
# NextAuth — Admin authentication for CMS
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
# ──────────────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ──────────────────────────────────────────────────────────────────────────────
# Admin credentials — used for CMS login (stored hashed at runtime)
# ──────────────────────────────────────────────────────────────────────────────
ADMIN_EMAIL="admin@bemarvelousdigital.com"
ADMIN_PASSWORD="replace-with-secure-password"

# ──────────────────────────────────────────────────────────────────────────────
# Site config
# ──────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://bemarvelousdigital.com"

# ──────────────────────────────────────────────────────────────────────────────
# Analytics — only loaded after user cookie consent
# ──────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_META_PIXEL_ID=""
