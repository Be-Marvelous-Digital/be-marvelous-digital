# ──────────────────────────────────────────────────────────────────────────────
# Database — SQLite (file-based, no separate server needed)
# ──────────────────────────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ──────────────────────────────────────────────────────────────────────────────
# NextAuth v5 — Admin authentication for CMS
# Generate with: openssl rand -base64 32
# ──────────────────────────────────────────────────────────────────────────────
AUTH_SECRET="replace-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# ──────────────────────────────────────────────────────────────────────────────
# Admin credentials — used for CMS login (stored hashed at runtime)
# ──────────────────────────────────────────────────────────────────────────────
ADMIN_EMAIL="admin@bemarvelousdigital.com"
ADMIN_PASSWORD="replace-with-secure-password"

# ──────────────────────────────────────────────────────────────────────────────
# Note: GA ID, Meta Pixel ID, and site URL are hardcoded in source code.
# Edit src/components/Analytics/GoogleAnalytics.tsx for GA ID.
# Edit src/components/Analytics/MetaPixel.tsx for Meta Pixel ID.
# ──────────────────────────────────────────────────────────────────────────────
