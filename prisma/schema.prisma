// Prisma schema for B-Marvels Digital CMS
// SQLite for simplicity — easy to migrate to PostgreSQL for production scaling

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Post {
  id          Int       @id @default(autoincrement())
  title       String
  slug        String    @unique
  excerpt     String
  body        String    // HTML from Tiptap editor
  coverImage  String?   // Path or URL to cover image
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  author      String    @default("Peter Lehocky")

  // Slovak translations (nullable — falls back to EN if not provided)
  titleSk     String?
  slugSk      String?
  excerptSk   String?
  bodySk      String?

  @@map("posts")
}
